# === Core runtime ===
XH_DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"
XH_DB_POOL_MAX_SIZE=50
XH_DB_POOL_MAX_OVERFLOW=100
XH_DB_POOL_TIMEOUT_SECONDS=30
XH_DB_CONNECT_TIMEOUT_SECONDS=10
XH_DB_SLOW_CHECKOUT_PROBE_MS=250
XH_DB_POOL_HEALTHCHECK_IDLE_SECONDS=15
XH_STORE_CREDENTIAL_ENCRYPTION_KEY="<generate-a-32+-char-random-secret>"
XH_TAKEALOT_API_KEY="<takealot-api-key>"
XH_TAKEALOT_ORDER_PAGE_LIMIT=10
XH_TAKEALOT_ORDER_MAX_PAGES=50
XH_TAKEALOT_ORDER_SYNC_LOOKBACK_DAYS=30
XH_TAKEALOT_ORDER_SYNC_FALLBACK_CHUNK_DAYS=7
XH_TAKEALOT_ORDER_AUTO_SYNC_INTERVAL_MINUTES=30
XH_TAKEALOT_ORDER_AUTO_SYNC_BATCH_SIZE=50
XH_DASHBOARD_BUSINESS_TIMEZONE="Africa/Johannesburg"
XH_DASHBOARD_VIEWER_TIMEZONE="Asia/Shanghai"
XH_DASHBOARD_ORDER_SYNC_STALE_MINUTES=60
XH_DASHBOARD_ZAR_CNY_RATE=0.42

# === Production safety ===
XH_SESSION_COOKIE_SECURE=true
XH_DB_BOOTSTRAP_DEMO_DATA=false

# === Public webhook ===
XH_TAKEALOT_WEBHOOK_SECRET="<webhook-secret>"
XH_TAKEALOT_WEBHOOK_PUBLIC_URL="https://<your-domain>/api/webhook/takealot"
XH_TAKEALOT_WEBHOOK_STORE_ID="<primary-takealot-store-id>"

# === Alerts ===
XH_ALERT_WEBHOOK_URL="https://<your-alert-endpoint>"

# === Post-deploy warmup / load gate ===
XH_LOAD_BASE_URL="https://<your-domain>"
XH_LOAD_USERNAME="tenant_admin"
XH_LOAD_PASSWORD="<load-test-password>"

# === Optional extension / catalogue enrichment ===
# Use one of the following for seller catalogue enrichment.
# XH_TAKEALOT_CATALOG_API_KEY="<seller-api-bearer>"
# XH_TAKEALOT_CATALOG_EMAIL="<seller-email>"
# XH_TAKEALOT_CATALOG_PASSWORD="<seller-password>"

# === Optional tuning ===
# XH_PLATFORM_API_TIMEOUT_SECONDS=15
# XH_WORKER_POLL_INTERVAL_SECONDS=2
# API_PROXY_TARGET="http://127.0.0.1:8000"
