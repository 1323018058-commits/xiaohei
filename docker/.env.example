# ProfitLens v3 — Environment Variables
# Copy this file to .env and fill in your values.

# --- Application ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-string-in-production
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- PostgreSQL ---
POSTGRES_PASSWORD=profitlens_dev_2024
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Encryption (32 bytes, hex-encoded) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PROFITLENS_DATA_KEY=

# --- External APIs ---
DEEPSEEK_API_KEY=
AMAZON_886IT_API_KEY=

# --- Uvicorn ---
UVICORN_WORKERS=4
BACKEND_PORT=8000

# --- Celery ---
CELERY_DEFAULT_CONCURRENCY=4
CELERY_LISTING_CONCURRENCY=2

# --- Nginx ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Flower (Celery monitoring) ---
FLOWER_PORT=5555
