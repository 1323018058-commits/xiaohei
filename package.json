{
  "name": "xiaohei-erp",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:api": "python -m uvicorn api_main:app --reload --app-dir apps/api",
    "dev:web": "npm --workspace @xiaohei/web run dev",
    "build:web": "npm --workspace @xiaohei/web run build",
    "db:migrate": "python packages/db/scripts/apply_dir.py packages/db/migrations",
    "db:seed": "python packages/db/scripts/apply_dir.py packages/db/seeds",
    "db:prepare": "npm run db:migrate && npm run db:seed",
    "db:smoke": "python packages/db/scripts/smoke_control_plane.py",
    "db:smoke:commercial": "python packages/db/scripts/smoke_commercial_guardrails.py",
    "db:smoke:subscription": "python packages/db/scripts/smoke_subscription_limits.py",
    "db:smoke:tenant-onboarding": "python packages/db/scripts/smoke_tenant_onboarding.py",
    "db:smoke:tenant-lifecycle": "python packages/db/scripts/smoke_tenant_lifecycle.py",
    "db:smoke:billing-lifecycle": "python packages/db/scripts/smoke_billing_lifecycle.py",
    "db:smoke:tenant-self-service": "python packages/db/scripts/smoke_tenant_self_service.py",
    "db:smoke:extension-guardrail": "python packages/db/scripts/smoke_extension_guardrail_closure.py",
    "db:smoke:task-ops": "python packages/db/scripts/smoke_task_ops.py",
    "db:smoke:orders": "python packages/db/scripts/smoke_order_sync.py",
    "db:smoke:store-sync": "python packages/db/scripts/mock_store_sync_failures.py",
    "db:smoke:worker-recovery": "python packages/db/scripts/smoke_worker_recovery.py",
    "load:commercial:smoke": "python packages/db/scripts/load_commercial_baseline.py --local-asgi --users 10 --iterations 1 --concurrency 5 --no-fail",
    "load:commercial": "powershell -ExecutionPolicy Bypass -File scripts/load-commercial.ps1",
    "api:warmup": "powershell -ExecutionPolicy Bypass -File scripts/warmup-api.ps1",
    "ops:guardrails": "powershell -ExecutionPolicy Bypass -File scripts/ops-guardrails.ps1",
    "ops:guardrails:strict": "powershell -ExecutionPolicy Bypass -File scripts/ops-guardrails.ps1 -Strict",
    "release:preflight": "powershell -ExecutionPolicy Bypass -File scripts/release-preflight.ps1",
    "host:check": "powershell -ExecutionPolicy Bypass -File scripts/host-activation-check.ps1",
    "ops:env:check": "powershell -ExecutionPolicy Bypass -File scripts/env-readiness.ps1",
    "ops:env:check:nofail": "powershell -ExecutionPolicy Bypass -File scripts/env-readiness.ps1 -NoFail",
    "ops:secrets:rotate-store-key": "powershell -ExecutionPolicy Bypass -File scripts/rotate-store-credential-key.ps1",
    "takealot:real-sync": "python packages/db/scripts/takealot_real_sync.py",
    "takealot:real-offer:preflight": "python packages/db/scripts/takealot_real_offer_preflight.py",
    "takealot:real-offer:create": "python packages/db/scripts/takealot_real_offer_create.py",
    "takealot:offer-write-probe": "python packages/db/scripts/takealot_offer_write_probe.py",
    "takealot:seller:apply-buyable": "python packages/db/scripts/takealot_seller_apply_buyable.py",
    "takealot:import-leadtime-warehouse": "python packages/db/scripts/takealot_import_leadtime_warehouse.py",
    "takealot:leadtime:probe": "python packages/db/scripts/takealot_leadtime_buyable_probe.py",
    "takealot:real-list-now": "python packages/db/scripts/takealot_real_list_now.py",
    "takealot:selection:crawl": "python packages/db/scripts/takealot_selection_crawl.py",
    "takealot:selection:discover-categories": "python packages/db/scripts/takealot_selection_discover_categories.py",
    "worker:api": "python apps/api/worker_main.py",
    "worker:api:once": "python apps/api/worker_main.py --once",
    "worker:api:ps": "powershell -ExecutionPolicy Bypass -File scripts/worker-api.ps1",
    "worker:api:ps:once": "powershell -ExecutionPolicy Bypass -File scripts/worker-api.ps1 -Once",
    "worker:schedule:dry": "powershell -ExecutionPolicy Bypass -File scripts/install-worker-scheduled-task.ps1",
    "worker:schedule:install": "powershell -ExecutionPolicy Bypass -File scripts/install-worker-scheduled-task.ps1 -Install",
    "ops:schedule:dry": "powershell -ExecutionPolicy Bypass -File scripts/install-ops-guardrails-scheduled-task.ps1",
    "ops:schedule:install": "powershell -ExecutionPolicy Bypass -File scripts/install-ops-guardrails-scheduled-task.ps1 -Install",
    "ops:alert:test": "powershell -ExecutionPolicy Bypass -File scripts/test-alert-channel.ps1",
    "ops:alert:test:strict": "powershell -ExecutionPolicy Bypass -File scripts/test-alert-channel.ps1 -RequireWebhook",
    "ops:alerts": "powershell -ExecutionPolicy Bypass -File scripts/list-alerts.ps1",
    "ops:alerts:json": "powershell -ExecutionPolicy Bypass -File scripts/list-alerts.ps1 -Json",
    "ops:data:check": "powershell -ExecutionPolicy Bypass -File scripts/data-integrity-check.ps1",
    "ops:data:check:strict": "powershell -ExecutionPolicy Bypass -File scripts/data-integrity-check.ps1 -Strict",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/db-backup.ps1",
    "db:restore:check": "powershell -ExecutionPolicy Bypass -File scripts/db-restore-check.ps1",
    "takealot:reconcile": "python packages/db/scripts/takealot_reconcile.py",
    "takealot:real-orders": "python packages/db/scripts/takealot_real_orders.py",
    "takealot:portal-probe": "python packages/db/scripts/takealot_portal_probe.py",
    "generate:openapi": "python apps/api/src/platform/openapi/export.py",
    "generate:api": "npm run generate:openapi && openapi-typescript packages/generated/openapi.json -o apps/web/src/generated/api-types.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1"
  }
}
